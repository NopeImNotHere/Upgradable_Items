UAI {
    permission UpgradeItems.rank
    help Main Command to all other Commands

    GUI-Open {
    permission UpgradeItems.GUI
    help Opens GUI for the Upgrade Table
    user player
    hook UIGuiOpen
    }

    Spawn-Creature-NPC entityType:entity* string:customName? {
    permission UpgradeItems.NPC-Creature
    help Spawn the Entity of choice to Open the GUI
    user player
    hook UISpawnCreatureNPC
    }
}

